<Page
    x:Class="Frost.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Frost.Models"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Text="Plugins"
                FontSize="28"
                FontWeight="SemiBold"
                TextTrimming="CharacterEllipsis"
                Margin="16,4,0,0"/>

            <CommandBar Background="Transparent" IsOpen="False" DefaultLabelPosition="Right" HorizontalAlignment="Right">
                <CommandBar.PrimaryCommands>
                    <!-- Sorting ComboBox -->
                    <AppBarButton Icon="Sort" IsCompact="True" ToolTipService.ToolTip="Sort" AutomationProperties.Name="Sort">
                        <AppBarButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Alphabetically (A-Z)" Click="SortMenuFlyoutItem_Click" Tag="Alphabetically_AZ"/>
                                <MenuFlyoutItem Text="Alphabetically (Z-A)" Click="SortMenuFlyoutItem_Click" Tag="Alphabetically_ZA"/>
                                <MenuFlyoutItem Text="Newest Added" Click="SortMenuFlyoutItem_Click" Tag="Newest"/>
                                <MenuFlyoutItem Text="Oldest Added" Click="SortMenuFlyoutItem_Click" Tag="Oldest"/>
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>

                    <AppBarSeparator />
                    <!-- Add Button -->
                    <AppBarButton Icon="Add" Click="OpenAddPluginDialog_Click" Label="Add" ToolTipService.ToolTip="Add Plugin" />
                </CommandBar.PrimaryCommands>
            </CommandBar>
        </Grid>

        <GridView
            x:Name="ContentGridView"
            Grid.Row="1"
            ItemsSource="{x:Bind Plugins, Mode=OneWay}"
            IsItemClickEnabled="True"
            SelectionMode="Single"
            CanDragItems="True"
            AllowDrop="True"
            CanReorderItems="True"
            ItemClick="ContentGridView_ItemClick"
            SelectionChanged="ContentGridView_SelectionChanged"
            RightTapped="GridView_RightTapped" >

            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem" BasedOn="{StaticResource DefaultGridViewItemStyle}">
                    <Setter Property="Margin" Value="9, 9, 9, 9"/>
                </Style>
            </GridView.ItemContainerStyle>

            <!-- Plugin Card Data Template -->
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:Plugin">
                    <Border CornerRadius="8" Padding="8" Width="240" Height="90">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" ToolTipService.ToolTip="{x:Bind Name}">
                                <Border Width="35" Height="54" CornerRadius="4" Margin="10">
                                    <Image
                                        Source="{x:Bind IconUrl}"
                                        Width="35"
                                        Height="54"
                                        Stretch="Fill"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock
                                        Text="{x:Bind Name}"
                                        FontWeight="Bold"
                                        FontSize="14"
                                        TextTrimming="CharacterEllipsis"
                                        Margin="8,18,0,0"/>
                                    <TextBlock
                                        Text="{x:Bind Developer}"
                                        FontSize="12"
                                        TextTrimming="CharacterEllipsis"
                                        Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>

    <Page.Resources>
        <MenuFlyout x:Key="PluginContextMenuFlyout">
            <MenuFlyoutItem Text="Edit" Icon="Edit" Click="EditPluginContextMenu_Click" />
            <MenuFlyoutItem Text="Delete" Icon="Delete" Click="DeletePluginContextMenu_Click" />
            <MenuFlyoutItem Text="Launch" Icon="Play" Click="LaunchPluginContextMenu_Click" />
        </MenuFlyout>
    </Page.Resources>
</Page>
