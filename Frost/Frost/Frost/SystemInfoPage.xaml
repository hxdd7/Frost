<Page
    x:Class="Frost.Pages.SystemInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock Text="System Information"
                       FontSize="24"
                       FontWeight="SemiBold" />

            <!-- CPU -->
            <Border CornerRadius="8" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Processor" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind CpuName, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind CpuCores, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <!-- GPU -->
            <Border CornerRadius="8" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Graphics Card" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind GpuName, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind GpuVram, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <!-- RAM -->
            <Border CornerRadius="8" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Memory" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind Ram, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <!-- OS -->
            <Border CornerRadius="8" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Operating System" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind OSVersion, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
