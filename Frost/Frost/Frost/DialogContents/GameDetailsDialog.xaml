<Page
    x:Class="Frost.DialogContents.GameDetailsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Frost.DialogContents"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:models="using:Frost.Models"
    Width="600" Height="250">

    <Grid Padding="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- Cover Image -->
        <Border Grid.Column="0" CornerRadius="8" HorizontalAlignment="Left">
            <Image x:Name="GameCoverImage"
                   Stretch="UniformToFill"
                   Width="150"
                   Height="225"
                   HorizontalAlignment="Center"
                   VerticalAlignment="center" />
        </Border>

        <!-- Details Section -->
        <StackPanel Grid.Column="1" VerticalAlignment="Top" Spacing="10" HorizontalAlignment="left" Width="300" MaxWidth="300">
            <TextBlock x:Name="GameTitle"
                       FontSize="28"
                       Margin="0,10,0,0"
                       FontWeight="Bold"
                       TextWrapping="WrapWholeWords" />
            <TextBlock x:Name="GameCompany"
                       FontSize="16"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="WrapWholeWords" />
            <TextBlock x:Name="GameSize"
                       FontSize="16"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="WrapWholeWords" />
            <!-- <Button Content="Open Location"
                    Click="OpenLocation_Click"
                    Tag="{Binding ExePath}" /> -->
            <Button Content="View Full Details"
                Click="ViewFullDetails_Click"
                Foreground="{ThemeResource AccentButtonBackground}"
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Left"
                FontSize="14"
                FontWeight="SemiBold"
                Padding="0" />

            <ScrollViewer x:Name="TagsScrollViewer">
                <muxc:ItemsRepeater x:Name="TagsRepeater"
                        ItemsSource="{x:Bind GameTags, Mode=OneWay}">
                    <muxc:ItemsRepeater.Layout>
                        <controls:WrapLayout
                            HorizontalSpacing="6"
                            VerticalSpacing="6" />
                    </muxc:ItemsRepeater.Layout>
                    <muxc:ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border
                                Background="{ThemeResource ControlAltFillColorQuarternaryBrush}"
                                CornerRadius="16">
                                <TextBlock Text="{x:Bind}"
                                    Margin="8,4"
                                    Padding="7,4"
                                    FontSize="14"
                                    Foreground="White"
                                    TextWrapping="NoWrap"
                                    TextTrimming="None"
                                    HorizontalAlignment="Left" />
                            </Border>
                        </DataTemplate>
                    </muxc:ItemsRepeater.ItemTemplate>
                </muxc:ItemsRepeater>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>
