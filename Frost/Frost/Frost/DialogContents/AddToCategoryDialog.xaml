<Page
    x:Class="Frost.DialogContents.AddToCategoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="12" Width="400" Margin="0 12 0 0">

        <TextBlock Text="Add to category:"/>

        <!-- Wrap in a fixed-height ScrollViewer -->
        <ScrollViewer x:Name="CategoryScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      MaxHeight="300"
                      Height="{x:Bind ScrollViewerHeight, Mode=OneWay}">
            <StackPanel x:Name="CategoryCheckBoxPanel" />
        </ScrollViewer>

        <TextBlock Text="Or create a new category:"/>
        <TextBox x:Name="NewCategoryTextBox"
                 PlaceholderText="Type new category name"
                 KeyDown="NewCategoryTextBox_KeyDown"/>
    </StackPanel>
</Page>
