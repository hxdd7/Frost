<Page
    x:Class="Frost.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Frost"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="20">
        <StackPanel Spacing="4">

            <TextBlock Text="Settings"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="16,4,0,0"/>

            <TextBlock Text="Appearance and behavior"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="18,26,0,6"/>

            <!-- Updated Theme Setting using SettingsCard -->
            <controls:SettingsCard
                Header="App Theme"
                Description="Select which app theme to display"
                HeaderIcon="{ui:FontIcon Glyph=&#xE790;}"
                Margin="16,0,0,0">
                <ComboBox x:Name="ThemeComboBox"
                          Width="200"
                          SelectionChanged="ThemeComboBox_SelectionChanged"
                          HorizontalAlignment="Right">
                    <ComboBoxItem Content="Use system setting"/>
                    <ComboBoxItem Content="Light"/>
                    <ComboBoxItem Content="Dark"/>
                </ComboBox>
            </controls:SettingsCard>

            <!-- Updated Sound Setting using SettingsCard -->
            <controls:SettingsCard
                Header="Sound"
                Description="Controls provide audible feedback"
                HeaderIcon="{ui:FontIcon Glyph=&#xEC4F;}"
                Margin="16,0,0,0">
                <ToggleSwitch x:Name="SoundToggle"
                              Toggled="SoundToggle_Toggled"
                              OffContent="Off"
                              OnContent="On"
                              HorizontalAlignment="Right"/>
            </controls:SettingsCard>

            <!-- About Section -->
            <TextBlock Text="About"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="18,30,0,6"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="4"
                    Padding="14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Margin="16,0,0,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <Grid VerticalAlignment="Center" HorizontalAlignment="Left">
                            <StackPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0">
                                <Border Width="24" Height="24">
                                    <Image
                                        Source="ms-appx:///Assets/Frost.png"
                                        Width="24"
                                        Height="24"
                                        Stretch="Fill"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="42,0,0,0">
                                <TextBlock Text="Krew" FontSize="14"/>
                                <TextBlock Text="© 2025 Amiru Weerathunga. All rights reserved." FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="1.0.0" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
