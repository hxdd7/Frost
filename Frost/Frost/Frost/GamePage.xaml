<Page
    x:Class="Frost.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Frost.Models"
    xmlns:converters="using:Frost.Converters"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Shared Context Menu -->
        <MenuFlyout x:Key="GameContextMenuFlyout">
            <MenuFlyoutItem Text="Edit" Icon="Edit" Click="EditGameContextMenu_Click" />
            <MenuFlyoutItem Text="Delete" Icon="Delete" Click="DeleteGameContextMenu_Click" />
            <MenuFlyoutItem Text="Launch" Icon="Play" Click="LaunchGameContextMenu_Click" />
            <MenuFlyoutItem x:Name="PinMenuItem" Text="Pin to Sidebar" Icon="Pin" Click="PinGameContextMenu_Click" />
            <MenuFlyoutItem x:Name="UnpinMenuItem" Text="Unpin from Sidebar" Icon="Unpin" Click="UnpinGameContextMenu_Click" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Add to Category" Icon="Tag"
                Tag="{Binding}" Click="AddToCategoryContextMenu_Click" />
        </MenuFlyout>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                 Text="Library"
                 FontSize="28"
                 FontWeight="SemiBold"
                 TextTrimming="CharacterEllipsis"
                 Margin="16,4,0,0"/>

            <CommandBar Background="Transparent" IsOpen="False" DefaultLabelPosition="Right" HorizontalAlignment="Right">
                <CommandBar.PrimaryCommands>
                    <AppBarButton Icon="Folder" IsCompact="True" Label="Drive" ToolTipService.ToolTip="Filter by Drive">
                        <AppBarButton.Flyout>
                            <MenuFlyout x:Name="DriveFilterFlyout" Placement="Bottom"/>
                        </AppBarButton.Flyout>
                    </AppBarButton>

                    <AppBarSeparator />

                    <AppBarButton Icon="Sort" IsCompact="True" Label="Sort" ToolTipService.ToolTip="Sort">
                        <AppBarButton.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem Text="Alphabetically (A-Z)" Click="SortMenuFlyoutItem_Click" Tag="Alphabetically_AZ"/>
                                <MenuFlyoutItem Text="Alphabetically (Z-A)" Click="SortMenuFlyoutItem_Click" Tag="Alphabetically_ZA"/>
                                <MenuFlyoutItem Text="Newest Added" Click="SortMenuFlyoutItem_Click" Tag="Newest"/>
                                <MenuFlyoutItem Text="Oldest Added" Click="SortMenuFlyoutItem_Click" Tag="Oldest"/>
                                <MenuFlyoutItem Text="Size (Smallest to Largest)" Click="SortMenuFlyoutItem_Click" Tag="Size_ASC"/>
                                <MenuFlyoutItem Text="Size (Largest to Smallest)" Click="SortMenuFlyoutItem_Click" Tag="Size_DESC"/>
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>

                    <AppBarButton Icon="Filter" IsCompact="True" Label="Filter" ToolTipService.ToolTip="Filter by Genre">
                        <AppBarButton.Flyout>
                            <MenuFlyout x:Name="GenreFilterFlyout" />
                        </AppBarButton.Flyout>
                    </AppBarButton>

                    <AppBarSeparator />

                    <AppBarButton Icon="Add" Click="OpenAddGameDialog_Click" Label="Add" ToolTipService.ToolTip="Add Game" />
                </CommandBar.PrimaryCommands>
            </CommandBar>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">
            <GridView
                x:Name="ContentGridView"
                ItemsSource="{x:Bind Games, Mode=OneWay}"
                IsItemClickEnabled="True"
                SelectionMode="Single"
                AllowDrop="True"
                CanReorderItems="True"
                ItemClick="ContentGridView_ItemClick"
                SelectionChanged="ContentGridView_SelectionChanged"
                RightTapped="GridView_RightTapped">

                <GridView.ItemContainerTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="100" />
                    </TransitionCollection>
                </GridView.ItemContainerTransitions>

                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem" BasedOn="{StaticResource DefaultGridViewItemStyle}">
                        <Setter Property="Margin" Value="9" />
                    </Style>
                </GridView.ItemContainerStyle>

                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:Game">
                        <Border CornerRadius="8" Padding="8" Width="330" Height="90">
                            <Grid>
                                <FontIcon 
                                    x:Name="IsPinnedIcon"
                                    Glyph="&#xEB52;"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    Foreground="{ThemeResource AccentTextFillColorTertiaryBrush}"
                                    FontSize="16"
                                    ToolTipService.ToolTip="Pinned"
                                    Visibility="{x:Bind IsPinned, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <StackPanel Orientation="Horizontal" ToolTipService.ToolTip="{Binding Name}">
                                    <Border Width="35" Height="54" CornerRadius="4" Margin="10,0,10,0">
                                        <Image
                                            Source="{Binding CoverImgUrl}"
                                            Width="35"
                                            Height="54"
                                            Stretch="Fill"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock
                                            Text="{Binding Name}"
                                            FontWeight="Bold"
                                            FontSize="14"
                                            TextTrimming="CharacterEllipsis"
                                            MaxWidth="220"/>
                                        <TextBlock
                                            Text="{Binding Company}"
                                            FontSize="12"
                                            TextTrimming="CharacterEllipsis"
                                            MaxWidth="220"/>
                                        <TextBlock
                                            Text="{Binding InstallSizeFormatted}"
                                            FontSize="12"
                                            TextTrimming="CharacterEllipsis"
                                            MaxWidth="220"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
