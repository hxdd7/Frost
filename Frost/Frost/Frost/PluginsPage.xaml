<Page
    x:Class="Frost.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Frost.Models"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Text="Plugins"
                FontSize="28"
                FontWeight="SemiBold"
                TextTrimming="CharacterEllipsis"
                Margin="16,4,0,0"/>

            <CommandBar Background="Transparent"
                        IsOpen="False"
                        DefaultLabelPosition="Right"
                        HorizontalAlignment="Right">
                <CommandBar.PrimaryCommands>

                    <AppBarButton Icon="Sort"
                                  IsCompact="True"
                                  ToolTipService.ToolTip="Sort">
                        <AppBarButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Alphabetically (A-Z)"
                                                Click="SortMenuFlyoutItem_Click"
                                                Tag="Alphabetically_AZ"/>
                                <MenuFlyoutItem Text="Alphabetically (Z-A)"
                                                Click="SortMenuFlyoutItem_Click"
                                                Tag="Alphabetically_ZA"/>
                                <MenuFlyoutItem Text="Newest Added"
                                                Click="SortMenuFlyoutItem_Click"
                                                Tag="Newest"/>
                                <MenuFlyoutItem Text="Oldest Added"
                                                Click="SortMenuFlyoutItem_Click"
                                                Tag="Oldest"/>
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>

                    <AppBarSeparator />

                    <AppBarButton Icon="Add"
                                  Click="OpenAddPluginDialog_Click"
                                  Label="Add"
                                  ToolTipService.ToolTip="Add Plugin" />
                </CommandBar.PrimaryCommands>
            </CommandBar>
        </Grid>

        <!-- CONTENT AREA -->
        <Grid Grid.Row="1">

            <!-- GRIDVIEW (UNCHANGED) -->
            <GridView
                x:Name="ContentGridView"
                ItemsSource="{x:Bind Plugins, Mode=OneWay}"
                IsItemClickEnabled="True"
                SelectionMode="Single"
                CanDragItems="True"
                AllowDrop="True"
                CanReorderItems="True"
                ItemClick="ContentGridView_ItemClick"
                SelectionChanged="ContentGridView_SelectionChanged"
                RightTapped="GridView_RightTapped">

                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem"
                           BasedOn="{StaticResource DefaultGridViewItemStyle}">
                        <Setter Property="Margin" Value="9,9,9,9"/>
                    </Style>
                </GridView.ItemContainerStyle>

                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:Plugin">
                        <Border CornerRadius="8"
                                Padding="8"
                                Width="240"
                                Height="90">
                            <StackPanel Orientation="Horizontal"
                                        ToolTipService.ToolTip="{x:Bind Name}">
                                <Border Width="35"
                                        Height="54"
                                        CornerRadius="4"
                                        Margin="10">
                                    <Image Source="{x:Bind IconUrl}"
                                           Width="35"
                                           Height="54"
                                           Stretch="Fill"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Name}"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="8,18,0,0"/>
                                    <TextBlock Text="{x:Bind Developer}"
                                               FontSize="12"
                                               Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- EMPTY PLACEHOLDER OVERLAY -->
            <StackPanel x:Name="EmptyPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Visibility="Collapsed">

                <FontIcon Glyph="&#xE74C;"
                          FontSize="56"
                          Opacity="0.6"
                          HorizontalAlignment="Center"/>

                <TextBlock Text="No plugins added"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Add your first plugin to get started"
                           Opacity="0.6"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>

    <Page.Resources>
        <MenuFlyout x:Key="PluginContextMenuFlyout">
            <MenuFlyoutItem Text="Edit" Icon="Edit" Click="EditPluginContextMenu_Click" />
            <MenuFlyoutItem Text="Delete" Icon="Delete" Click="DeletePluginContextMenu_Click" />
            <MenuFlyoutItem Text="Launch" Icon="Play" Click="LaunchPluginContextMenu_Click" />
        </MenuFlyout>
    </Page.Resources>
</Page>
